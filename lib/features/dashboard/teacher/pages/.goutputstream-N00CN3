import 'package:flutter/material.dart';
import 'package:flutter/foundation.dart';
import 'package:provider/provider.dart';
import 'package:supabase_flutter/supabase_flutter.dart';
import 'package:smartedu/core/providers/teacher/teacher_provider.dart';
import 'package:smartedu/utils/grading_utils.dart';

class TeacherEnterScoresPage extends StatefulWidget {
  const TeacherEnterScoresPage({super.key});
  @override
  State<TeacherEnterScoresPage> createState() => _TeacherEnterScoresPageState();
}

class _TeacherEnterScoresPageState extends State<TeacherEnterScoresPage> {
  String? _selectedClassId;
  String? _selectedSubjectId;
  String? _selectedTermId;
  bool _isSaving = false;
  final Map<String, TextEditingController> _scoreControllers = {};
  final Map<String, TextEditingController> _behavioralControllers = {};
  final Set<String> _prefilledStudents = {};

  static const List<Map<String, String>> _behavioralFields = [
    {'key': 'conduct', 'label': 'Conduct'},
    {'key': 'attitude', 'label': 'Attitude'},
    {'key': 'interest', 'label': 'Interest'},
    {'key': 'punctuality', 'label': 'Punctuality'},
  ];

  static const List<String> _behavioralOptions = ['Excellent', 'Very Good', 'Good', 'Fair', 'Poor'];

  @override
  void dispose() {
    for (final c in _scoreControllers.values) c.dispose();
    for (final c in _behavioralControllers.values) c.dispose();
    super.dispose();
  }

  String _studentName(Map<String, dynamic> s) {
    final first = (s['first_name'] ?? '').toString().trim();
    final last = (s['last_name'] ?? '').toString().trim();
    return '$first $last'.trim();
  }

  List<Map<String, dynamic>> get _assessmentTypes {
    final provider = context.read<TeacherProvider>();
    final types = provider.assessmentTypes;
    if (types.isNotEmpty) return types;
    return GradingUtils.getDefaultAssessmentTypes('WAEC');
  }

  List<Map<String, dynamic>> get _gradingSystem {
    final provider = context.read<TeacherProvider>();
    final gs = provider.gradingSystem;
    if (gs.isNotEmpty) return gs;
    return GradingUtils.getDefaultGradingSystem('WAEC');
  }

  double _getMaxForAssessment(Map<String, dynamic> assessment) {
    return (assessment['max'] as num?)?.toDouble() ?? 100;
  }

  double get _totalMaxScore {
    return _assessmentTypes.fold<double>(0, (sum, at) => sum + _getMaxForAssessment(at));
  }

  List<Map<String, dynamic>> get _filteredStudents {
    if (_selectedClassId == null) return [];
    return context.read<TeacherProvider>().getStudentsInClass(_selectedClassId!);
  }

  void _clearAllControllers() {
    for (var c in _scoreControllers.values) c.dispose();
    for (var c in _behavioralControllers.values) c.dispose();
    _scoreControllers.clear();
    _behavioralControllers.clear();
    _prefilledStudents.clear();
  }

  TextEditingController _getScoreController(String studentId, String assessmentId) {
    final key = '${studentId}_$assessmentId';
    _scoreControllers[key] ??= TextEditingController();
    return _scoreControllers[key]!;
  }

  TextEditingController _getBehavioralController(String studentId, String field) {
    final key = '${studentId}_$field';
    _behavioralControllers[key] ??= TextEditingController();
    return _behavioralControllers[key]!;
  }

  double _computeStudentTotal(String studentId) {
    double total = 0;
    for (final at in _assessmentTypes) {
      final aid = (at['id'] ?? '').toString();
      total += double.tryParse(_getScoreController(studentId, aid).text) ?? 0;
    }
    return total;
  }

  String _calcGrade(double score) {
    for (final g in _gradingSystem) {
      final min = (g['min'] as num?)?.toDouble() ?? 0;
      final max = (g['max'] as num?)?.toDouble() ?? 100;
      if (score >= min && score <= max) return (g['grade'] ?? 'F').toString();
    }
    return 'F';
  }

  List<String> _validateScores() {
    final errors = <String>[];
    for (final student in _filteredStudents) {
      final sid = student['id'].toString();
      final name = _studentName(student);
      for (final at in _assessmentTypes) {
        final aid = (at['id'] ?? '').toString();
        final label = (at['name'] ?? aid).toString();
        final max = _getMaxForAssessment(at);
        final val = double.tryParse(_getScoreController(sid, aid).text) ?? 0;
        if (val < 0) errors.add('$name: $label cannot be negative');
        else if (val > max) errors.add('$name: $label exceeds maximum of $max');
      }
      final total = _computeStudentTotal(sid);
      if (total > _totalMaxScore) errors.add('$name: Total ($total) exceeds maximum of $_totalMaxScore');
    }
    return errors;
  }

  Future<void> _prefillExistingScores() async {
    for (final student in _filteredStudents) {
      final sid = student['id'].toString();
      if (_prefilledStudents.contains(sid)) continue;
      try {
        final provider = context.read<TeacherProvider>();
        final existing = await provider.getExistingScore(sid, _selectedSubjectId!);
        if (existing != null) {
          final scoresJson = existing['scores_json'] as Map<String, dynamic>? ?? {};
          for (final at in _assessmentTypes) {
            final aid = (at['id'] ?? '').toString().toLowerCase();
            final val = scoresJson[aid] ?? scoresJson[at['name']] ?? 0;
            _getScoreController(sid, aid).text = (val is num ? val : 0).toString();
          }
        }
        final behavioral = await _getExistingBehavioral(sid, _selectedTermId!);
        if (behavioral != null) {
          for (final field in _behavioralFields) {
            final key = field['key']!;
            final val = behavioral[key] ?? '';
            if (val.toString().isNotEmpty) _getBehavioralController(sid, key).text = val.toString();
          }
          final tc = behavioral['teacher_comment'] ?? '';
          if (tc.toString().isNotEmpty) _getBehavioralController(sid, 'teacher_comment').text = tc.toString();
        }
      } catch (e) {
        debugPrint('Error prefilling for $sid: $e');
      }
      _prefilledStudents.add(sid);
    }
  }

  Future<Map<String, dynamic>?> _getExistingBehavioral(String studentId, String termId) async {
    try {
      final provider = context.read<TeacherProvider>();
      return await Supabase.instance.client.from('term_comments').select().eq('school_id', provider.schoolId).eq('student_id', studentId).eq('term_id', termId).maybeSingle();
    } catch (e) {
      debugPrint('Error fetching behavioral: $e');
      return null;
    }
  }

  Future<bool> _saveBehavioralRating({required String studentId, required String classId, required String termId, Map<String, dynamic>? behavioralData}) async {
    try {
      final provider = context.read<TeacherProvider>();
      final sessionId = provider.currentSession?['id']?.toString();
      final existing = await Supabase.instance.client.from('term_comments').select('id').eq('school_id', provider.schoolId).eq('student_id', studentId).eq('term_id', termId).eq('class_id', classId).maybeSingle();
      final payload = <String, dynamic>{'school_id': provider.schoolId, 'student_id': studentId, 'session_id': sessionId, 'term_id': termId, 'class_id': classId};
      if (behavioralData != null) payload.addAll(behavioralData);
      if (existing != null) {
        await Supabase.instance.client.from('term_comments').update(payload).eq('id', existing['id']);
      } else {
        payload['teacher_comment'] = '';
        await Supabase.instance.client.from('term_comments').insert(payload);
      }
      return true;
    } catch (e) {
      debugPrint('Error saving behavioral rating: $e');
      return false;
    }
  }

  Future<void> _onSaveScores() async {
    final errors = _validateScores();
    if (errors.isNotEmpty) { _showValidationErrors(errors); return; }
    final confirmed = await showDialog<bool>(context: context, builder: (ctx) => AlertDialog(title: const Text('Confirm Save'), content: Text('Save scores for ${_filteredStudents.length} students?'), actions: [TextButton(onPressed: () => Navigator.pop(ctx, false), child: const Text('Cancel')), ElevatedButton(onPressed: () => Navigator.pop(ctx, true), style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF0D47A1)), child: const Text('Save', style: TextStyle(color: Colors.white)))]));
    if (confirmed != true) return;
    setState(() => _isSaving = true);
    try {
      final provider = context.read<TeacherProvider>();
      final sessionId = provider.currentSession?['id']?.toString();
      for (final student in _filteredStudents) {
        final sid = student['id'].toString();
        final scoresJson = <String, dynamic>{};
        for (final at in _assessmentTypes) {
          final aid = (at['id'] ?? '').toString().toLowerCase();
          scoresJson[aid] = double.tryParse(_getScoreController(sid, aid).text) ?? 0;
        }
        final total = _computeStudentTotal(sid);
        final grade = _calcGrade(total);
        await Supabase.instance.client.from('scores').insert({'school_id': provider.schoolId, 'student_id': sid, 'class_id': _selectedClassId, 'subject_id': _selectedSubjectId, 'session_id': sessionId, 'term_id': _selectedTermId, 'scores_json': scoresJson, 'total': total, 'grade': grade, 'recorded_by': provider.teacherId});
        final behavioralData = <String, dynamic>{};
        for (final field in _behavioralFields) {
          final key = field['key']!;
          final val = _getBehavioralController(sid, key).text.trim();
          if (val.isNotEmpty) behavioralData[key] = val;
        }
        final comment = _getBehavioralController(sid, 'teacher_comment').text.trim();
        if (comment.isNotEmpty) behavioralData['teacher_comment'] = comment;
        if (behavioralData.isNotEmpty) await _saveBehavioralRating(studentId: sid, classId: _selectedClassId!, termId: _selectedTermId!, behavioralData: behavioralData);
      }
      if (mounted) ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("Scores saved successfully!"), backgroundColor: Color(0xFF2E7D32)));
    } catch (e) {
      if (mounted) ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("Error saving: $e"), backgroundColor: Color(0xFFD32F2F)));
    } finally {
      if (mounted) setState(() => _isSaving = false);
    }
  }

  void _showValidationErrors(List<String> errors) {
    showDialog(context: context, builder: (ctx) => AlertDialog(title: const Row(children: [Icon(Icons.warning_amber_rounded, color: Color(0xFFD32F2F)), SizedBox(width: 8), Text('Validation Errors')]), content: Column(mainAxisSize: MainAxisSize.min, crossAxisAlignment: CrossAxisAlignment.start, children: [const Text('Please fix:', style: TextStyle(fontSize: 13, color: Colors.grey)), const SizedBox(height: 12), ...errors.take(5).map((e) => Padding(padding: const EdgeInsets.only(bottom: 6), child: Row(crossAxisAlignment: CrossAxisAlignment.start, children: [const Text('• ', style: TextStyle(color: Color(0xFFD32F2F), fontWeight: FontWeight.bold)), Expanded(child: Text(e, style: const TextStyle(fontSize: 13)))]))), if (errors.length > 5) Text('...and ${errors.length - 5} more', style: const TextStyle(fontSize: 12, color: Colors.grey))]), actions: [TextButton(onPressed: () => Navigator.pop(ctx), child: const Text('Fix Scores'))]));
  }

