                ..._assessmentTypes.map((at) { final aid = (at['id'] ?? '').toString(); return SizedBox(width: 90, child: Padding(padding: const EdgeInsets.symmetric(horizontal: 4, vertical: 4), child: TextField(controller: _getScoreController(sid, aid), keyboardType: const TextInputType.numberWithOptions(decimal: true), textAlign: TextAlign.center, style: const TextStyle(fontSize: 13), decoration: InputDecoration(border: OutlineInputBorder(borderRadius: BorderRadius.circular(6)), enabledBorder: OutlineInputBorder(borderRadius: BorderRadius.circular(6)), focusedBorder: OutlineInputBorder(borderRadius: BorderRadius.circular(6)), contentPadding: const EdgeInsets.symmetric(horizontal: 4, vertical: 8), isDense: true), onChanged: (_) => setState(() {}))); }),
